# ──────────────────────────────────────────────────────────────────────────────
# Forseti backend — Variables de entorno (PLANTILLA pública)
# ──────────────────────────────────────────────────────────────────────────────
# Este archivo SÍ se commitea (es .env.example). Sirve de plantilla.
# El archivo real .env (con valores propios) NO se commitea (está en .gitignore).
#
# Uso:
#   1) cp .env.example .env
#   2) Reemplazar los valores marcados con <...> por los tuyos
#   3) Spring Boot lee .env automáticamente si está en la carpeta de arranque
#      (con el plugin io.github.cdimascio:dotenv o spring-dotenv); también
#      podés cargarlo manualmente con:  set -a; source .env; set +a
# ──────────────────────────────────────────────────────────────────────────────


# ─── Perfil Spring ─────────────────────────────────────────────────────────────
# local | prod
SPRING_PROFILES_ACTIVE=local


# ─── HTTP ─────────────────────────────────────────────────────────────────────
SERVER_PORT=8080


# ─── Base de datos Postgres ───────────────────────────────────────────────────
# En local: usar tu Postgres del host (o docker compose up postgres).
# En prod: el VPS los lee de /etc/forseti/forseti.env, no de este archivo.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=forseti_local
POSTGRES_USER=forseti
POSTGRES_PASSWORD=<generar-con-openssl-rand-base64-24>


# ─── CRÍTICA: llave maestra de cifrado de .p12 (AES-256-GCM) ─────────────────
# 32 bytes en base64. Generar con:
#   openssl rand -base64 32
#
# ⚠️  IMPORTANTE:
#   - SI SE PIERDE, todos los .p12 cifrados quedan irrecuperables.
#   - Llaves de DEV y PROD DEBEN SER DISTINTAS.
#   - La de PROD vive en /etc/forseti/forseti.env del VPS — NO en este archivo.
#   - Si rotás, hay que re-cifrar los blobs existentes.
FORSETI_MASTER_KEY=<generar-con-openssl-rand-base64-32>


# ─── URLs / branding ──────────────────────────────────────────────────────────
# Base URL que se incrusta en correos (verify-email, reset-password, etc.)
FORSETI_BASE_URL=http://localhost:5173


# ─── SRI (URLs públicas, NO son secretos — defaults oficiales) ───────────────
# Los dejo explícitos para que se vean al revisar el .env, pero podés borrarlos
# y el backend usará los defaults compilados en application.yml.
FORSETI_SRI_PRUEBAS_RECEPCION=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline
FORSETI_SRI_PRUEBAS_AUTORIZACION=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline
FORSETI_SRI_PROD_RECEPCION=https://cel.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline
FORSETI_SRI_PROD_AUTORIZACION=https://cel.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline


# ─── Correo (Brevo SMTP) ──────────────────────────────────────────────────────
# En LOCAL: típicamente Mailpit corriendo en :1025 + UI :8025  (no necesita auth)
# En PROD: Brevo SMTP real con SMTP user + API key
BREVO_SMTP_HOST=localhost
BREVO_SMTP_PORT=1025
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=
BREVO_API_KEY=disabled
MAIL_FROM_NAME=Forseti
MAIL_FROM_ADDRESS=no-reply@forseti.local


# ─── R2 / B2 backups (Sprint 0+) ──────────────────────────────────────────────
# Solo aplica en prod. En local podés dejar en blanco.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=
